# PostgreSQL connection (matches docker-compose service name "db")
DATABASE_URL=postgresql://postgres:postgres@db:5432/medical_assistant

# Gemini (used for both embeddings and LLM generation)
GEMINI_API_KEY=your-gemini-api-key-here

# LLM / Embedding model selection
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=1536

# Retrieval tuning (Rule 3 — retrieve tightly)
SIMILARITY_THRESHOLD=0.75
TOP_K_RESULTS=4

# Chunking (Section 12.1)
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Gemini ingestion stability
EMBEDDING_REQUEST_DELAY_SECONDS=0.25
GEMINI_RETRY_ATTEMPTS=8
